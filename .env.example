HOST=127.0.0.1
PORT=3000

# Opsi 1: pakai DATABASE_URL
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/agendaguru

# Opsi 2: pakai variabel PG terpisah
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=agendaguru
PGUSER=postgres
PGPASSWORD=postgres

# Isi require bila koneksi Anda butuh SSL
# Turso DB Configuration (Production)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

